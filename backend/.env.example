# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recall_mvp

# OpenAI API Key
OPENAI_API_KEY=sk-...your-key-here

# Embedding Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Search Defaults
SEARCH_DEFAULT_LIMIT=5
SEARCH_MIN_SIMILARITY=0.3
SEARCH_MAX_CONTEXT_TOKENS=3000

# Deepgram Voice Agent (Optional)
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_ENABLED=false
MAX_VOICE_SESSION_MINUTES=15
MAX_VOICE_MINUTES_PER_DAY=60
DEEPGRAM_VOICE_MODEL=aura-2-andromeda-en
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_LLM_MODEL=gpt-4.1-nano

# Push Notifications - VAPID Keys (REQUIRED for push notifications)
# Generate with: vapid --gen
# Or: python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); print('Private:', v.private_pem().decode()); import base64; print('Public:', base64.urlsafe_b64encode(v.public_key.public_bytes_raw()).decode().rstrip('='))"
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_SUBJECT=mailto:admin@recall.local

# Authentication (REQUIRED for production)
# Set a strong API key for production. Leave empty for development (disables auth).
# Example: API_KEY=mySecureRandomKey123!@#
API_KEY=

# Environment
ENV=development
